# FIRST-TIME-ONLY (regenerated with --force). source: {{ source_file }}
#
# Impl slice — handler bodies. The user owns this BUILD.bazel after
# first emit (you may want to add per-FC test_*.cc files; gen-app
# won't reach in and squash that).

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# State structs (write-once, app-owned). A leaf header-only target so
# BOTH the lib (which #includes "impl/<Node>_state.hh" as the GenServer
# State type) and the impl can depend on it WITHOUT a lib<->impl cycle:
#   {{ model.fc_short }}_state  ←  lib  ←  impl
cc_library(
    name = "{{ model.fc_short }}_state",
    hdrs = [
{#- statem nodes carry their data in the FSM holder, and prebuilt nodes have no
    user state (the child binary is third-party) — neither emits a _state.hh. #}
{%- for n in model.nodes if not n.statem and not n.prebuilt and not n.imported %}
        "{{ n.name }}_state.hh",
{%- endfor %}
    ],
    # The lib #includes these as "impl/<Node>_state.hh", so the include
    # root is the FC out_dir (one above impl/).
    includes = [".."],
    copts = ["-std=c++17", "-fPIC"],
    deps = ["{{ platform_repo }}//platform/runtime:runtime"],
)

cc_library(
    name = "{{ model.fc_short }}_impl",
    srcs = [
{%- for n in model.nodes if not n.imported %}
        "{{ n.name }}_handlers.cc",
{%- endfor %}
    ],
    copts = [
        "-std=c++17",
        "-Wall",
        "-Wextra",
        "-fPIC",
    ],
    deps = [
        "//{{ model.bazel_pkg_prefix }}/lib:{{ model.fc_short }}_lib",
    ],
)
