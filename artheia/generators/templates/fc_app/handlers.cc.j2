// User handler bodies for {{ model.daemon_class }}.
//
// FIRST-TIME-ONLY SCAFFOLD. `artheia gen-app --kind fc` checks for
// this file's existence and refuses to overwrite unless `--force`
// is passed. Bodies are yours; the declarations are in
// lib/{{ model.daemon_class }}.hh.
//
// Default behaviour for every handler is a no-op (logs the message
// type to stderr so you can see traffic land). Replace with real
// behaviour as the FC matures.

#include "lib/{{ model.daemon_class }}.hh"

#include <cstdio>

namespace {{ model.cxx_namespace }} {

{% for n in model.nodes %}
{# ---- handle_cast (one per receiver-port data element) ---- #}
{%- for p in n.ports if p.kind == "receiver" %}
{%- for d in p.data %}
void {{ n.name }}::handle_cast(const {{ d.msg }}& /*msg*/,
                                 {{ n.name }}State& /*s*/) {
    // TODO: react to {{ p.name }}.{{ d.name }} ({{ p.iface }}).
    std::fprintf(stderr, "[%s] received {{ p.iface }}::{{ d.name }}\n",
                 kNodeName);
}
{% endfor %}
{%- endfor -%}

{# ---- handle_call (one per server-port operation) ---- #}
{%- for p in n.ports if p.kind == "server" %}
{%- for op in p.ops %}
{{ op.rep_msg or "void" }} {{ n.name }}::handle_call(
        const {{ op.req_msg }}& /*req*/,
        {{ n.name }}State& /*s*/) {
    // TODO: implement {{ p.iface }}::{{ op.name }}.
    std::fprintf(stderr, "[%s] {{ p.iface }}::{{ op.name }} called\n",
                 kNodeName);
    {%- if op.rep_msg %}
    return {{ op.rep_msg }}{};
    {%- endif %}
}
{% endfor %}
{%- endfor -%}
{% endfor %}

}  // namespace {{ model.cxx_namespace }}
