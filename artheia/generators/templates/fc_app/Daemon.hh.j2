inline uint32_t {{ n.name }}::subscribe_{{ p.name }}_{{ d.name }}(
        {{ p.name|capitalize }}{{ d.name|capitalize }}Subscriber s) {
    std::lock_guard<std::mutex> lk({{ p.name }}_{{ d.name }}_mu_);
    uint32_t id = {{ p.name }}_{{ d.name }}_next_id_++;
    {{ p.name }}_{{ d.name }}_subs_.push_back({id, std::move(s)});
    return id;
}

inline void {{ n.name }}::unsubscribe_{{ p.name }}_{{ d.name }}(uint32_t id) {
    std::lock_guard<std::mutex> lk({{ p.name }}_{{ d.name }}_mu_);
    auto& v = {{ p.name }}_{{ d.name }}_subs_;
    v.erase(std::remove_if(v.begin(), v.end(),
              [id](const auto& e) { return e.id == id; }), v.end());
}

inline void {{ n.name }}::broadcast_{{ p.name }}_{{ d.name }}(const {{ d.msg }}& msg) {
    // OTP-pg multicast: encode `msg` once and send ONE datagram to its TYPE's
    // process group {group_type, 0..~0} — the TIPC kernel fans out a copy to every
    // bound member (no per-member loop). group identity = msg_type_name<{{ d.msg }}>()
    // (the .art wire name); the supervisor allocates group_type the first time we
    // resolve it. Members receive it via register_cast<{{ d.msg }}> (same service_id),
    // so the receive path is the node's normal handle_cast. Best-effort (lossy).
    auto _g = pg_resolve<{{ d.msg }}>();
    if (!_g.ok) return;                       // supervisor unreachable — drop
    uint8_t _buf[8192];
    pb_ostream_t _os = pb_ostream_from_buffer(_buf, sizeof(_buf));
    if (!pb_encode(&_os, ::theia::runtime::RemoteCodec<{{ d.msg }}>::fields(), &msg))
        return;
    pg_.broadcast<{{ d.msg }}>(_g.type, _buf, static_cast<uint16_t>(_os.bytes_written));
}
