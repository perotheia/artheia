// main.example.cc — COPY-FROM REFERENCE for a --kind lib standalone app.
// AUTO-GENERATED by `artheia gen-app --kind lib`. NOT part of the build (the
// CMakeLists does not list it); copy it to your own main.cc / your event loop
// and adapt. Regenerated on every gen-app run — do not edit in place.
//
// --kind lib emits NO main slice on purpose: a standalone app (a CARLA sidecar,
// a QT GUI, a robot controller) owns its own main and event loop. What it does
// NOT own is the per-node mux wiring — that is codegen knowledge, and omitting
// any of it fails SILENTLY (frames simply never arrive). This file shows the
// correct wiring for THIS app's nodes so you don't have to reverse-engineer it.
//
// THE ORDER MATTERS — two passes, and they cannot be merged:
//   PASS 1  bind_node + register_cast<> + pg_attach   (wire the mux)
//           config_mux.start()                        (start pumping)
//   PASS 2  node.start()                              (runs init() on its thread)
// A node's init() may issue a BLOCKING call to the supervisor (pg_join,
// pg_watch). If start() ran before the mux pumped, that call would never get its
// reply, init() would hang, the node would never heartbeat, and the supervisor
// watchdog would SIGTERM it ~3s later. Wire first, pump, then start.
//
// TIPC identity: resolve_node_tipc() falls back to the compiled .art address
// when there is no --tipc arg — correct for an operator/systemd-launched sidecar
// (it is NOT a supervisor child, so it has no executor.json entry to shift it).
//
// TIPC NETID / cluster: NOT set here. The netid is per NETWORK NAMESPACE, not
// per process — a sidecar joins whatever cluster its netns is already in (the
// one the rig's supervisor bound). Set it on the HOST before launching
// (`sudo tipc node set netid <n>`, or THEIA_TIPC_NETID via the deploy path).

{% for n in model.nodes -%}
#include "lib/{{ n.name }}.hh"
{% endfor -%}
#include "lib/Log.hh"

#include "TipcMux.hh"
#include "TimerService.hh"
#include "Logger.hh"
#include "MachineInstance.hh"   // resolve_node_tipc / set_node_tipc_arg
#include "ParamsConfig.hh"      // init_config / get_config
#include "HeartbeatPublisher.hh"

#include <atomic>
#include <chrono>
#include <csignal>
#include <cstdio>
#include <cstdlib>
#include <memory>
#include <thread>
#include <vector>

namespace {
std::atomic<bool> g_running{true};
void on_signal(int /*sig*/) { g_running.store(false); }
}  // namespace

int main(int argc, char** argv) {
    std::signal(SIGINT,  on_signal);
    std::signal(SIGTERM, on_signal);

    // Accept --tipc=... if an operator passes one; else each node falls back to
    // its compiled .art address (the normal sidecar case).
    ::theia::runtime::set_node_tipc_arg(argc, argv);

    // Static params, loaded ONCE before any node is constructed. Missing file is
    // fine — every lookup falls back to the caller's default.
    ::theia::runtime::init_config("{{ model.fc_short }}");

    auto boot_level = ::theia::runtime::kDefaultLogLevel;
    if (const char* lvl = std::getenv("THEIA_LOG_LEVEL")) {
        boot_level = ::theia::runtime::parse_log_level(lvl);
    }

    ::theia::runtime::TimerService timers;
    ::theia::runtime::set_process_timers(&timers);

    // The one per-app mux (single epoll/select loop). Publish it so a handler's
    // ad-hoc RemoteRef registers its call-reply fd here.
    ::theia::runtime::TipcMux config_mux;
    ::theia::runtime::set_process_mux(&config_mux);

    std::vector<std::unique_ptr<::theia::runtime::HeartbeatPublisher>> heartbeats;

    using namespace {{ model.cxx_namespace }};

    {% for n in model.nodes %}
    // ---- {{ n.name }} ----------------------------------------------------
    {{ n.name }} {{ n.snake }};
    {
        auto lg = MakeContextLogger("{{ n.snake }}");
        lg->set_level(boot_level);
        {% if loop.first %}::theia::runtime::set_process_logger(lg);
        {% endif %}{{ n.snake }}.set_logger(std::move(lg));
    }
    uint32_t {{ n.snake }}_type, {{ n.snake }}_inst;
    ::theia::runtime::resolve_node_tipc("{{ n.snake }}",
        {{ n.name }}::kTipcType, {{ n.name }}::kTipcInstance,
        {{ n.snake }}_type, {{ n.snake }}_inst);
    {% if not n.runnable and not n.prebuilt -%}
    // set_tipc_instance() is a GenServer/GenStateM method — only atomic + statem
    // nodes have it. A runnable/prebuilt resolves its own instance in do_start.
    {{ n.snake }}.set_tipc_instance({{ n.snake }}_inst);
    {% endif -%}
    {% if n.needs_mux and not n.runnable %}
    // PASS 1 — wire the mux BEFORE it pumps and before the node thread. Only a
    // node that needs the mux (a GenServer that reports, serves an op, or has a
    // receiver/pg port) binds here; a pure runnable does its own wiring in
    // do_start.
    if (auto* {{ n.snake }}_cfg = config_mux.bind_node(
            {{ n.snake }}, {{ n.snake }}_type, {{ n.snake }}_inst)) {
        // Config-service edge — REPORTING nodes only (supervisor log-level /
        // trace pushes). A reporting=false node MUST skip these but still needs
        // the pg/receiver demux below.
        if ({{ n.name }}::kReporting) {
            config_mux.register_cast<platform_runtime_LogLevelPush>(
                {{ n.snake }}_cfg, {{ n.snake }});
            config_mux.register_cast<platform_runtime_TraceControlPush>(
                {{ n.snake }}_cfg, {{ n.snake }});
        }
        // pg demux — the node owns its membership: pg_join<T>()/pg_watch<T>()
        // from its own init()/handlers, never automatically here.
        {{ n.snake }}.pg_attach("{{ n.snake }}", {{ n.snake }}_cfg,
                                {{ n.snake }}_type, {{ n.snake }}_inst);
    } else {
        {{ n.snake }}.log().warn("mux bind failed; pg/receiver frames + live "
                                 "control pushes will NOT be delivered");
    }
    {% endif -%}
    {% endfor %}
    // The mux is wired for every node but no node thread runs yet. Pump BEFORE
    // any node.start() so a blocking pg_join/pg_watch in init() gets its reply.
    config_mux.start();

    {% for n in model.nodes %}
    // PASS 2 — start {{ n.name }} (init() runs on the node thread).
    {{ n.snake }}.start();
    if ({{ n.name }}::kReporting) {
        // Liveness beat — ONLY for a reporting node. A pid that has EVER beat
        // must keep beating (3s grace) or the watchdog evicts it; a
        // reporting=false node must NEVER start a publisher.
        auto hb = std::make_unique<::theia::runtime::HeartbeatPublisher>("{{ n.snake }}");
        if (hb->open()) { hb->start(1000); heartbeats.push_back(std::move(hb)); }
    }
    {% endfor %}
    // The app's own loop. A real sidecar drives CARLA / QT / a control rate here;
    // each node runs on its own thread and serves TIPC throughout.
    while (g_running.load()) {
        std::this_thread::sleep_for(std::chrono::milliseconds(100));
    }

    config_mux.stop();
    {% for n in model.nodes -%}
    {{ n.snake }}.stop("signal");
    {% endfor %}
    return 0;
}
