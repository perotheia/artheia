// User handler bodies for {{ node.name }} (STATEM variant).
//
// FIRST-TIME-ONLY SCAFFOLD. `artheia gen-fc` checks for
// this file's existence and refuses to overwrite unless `--force`
// is passed. Declarations are in lib/{{ node.name }}.hh.
//
// What lives here (user code):
//   - on_enter — fires after every committed FSM transition (and
//     once at init with new==old). Cast / send_after / log here.
//     Returns void, so transition_to() is COMPILE-TIME forbidden.
//   - handle_call overloads for any server-port operations — map
//     external requests onto FSM events or daemon state.
//
// Default bodies are no-ops with a stderr log so traffic is
// observable. Replace with real behaviour as the FC matures.

#include "lib/{{ node.name }}.hh"

#include <cstdio>

namespace {{ model.cxx_namespace }} {

{% set n = node %}

// on_enter — runs on the FSM thread AFTER every committed
// transition. The framework also fires it once at init with
// new_s == old_s == {{ n.statem.initial }}. SAFE to call
// cast/post_event/broadcast from here; UNSAFE to transition.
void {{ n.name }}::on_enter({{ n.name }}State new_s,
                              {{ n.name }}State /*old_s*/,
                              {{ n.name }}Data& /*d*/) {
    static const char* names[] = {
{%- for s in n.statem.states %}
        "{{ s }}",
{%- endfor %}
    };
    const auto idx = static_cast<std::size_t>(new_s);
    std::fprintf(stderr, "[%s] → %s\n",
                 kNodeName,
                 idx < sizeof(names)/sizeof(names[0]) ? names[idx] : "?");
    // TODO: fan out to subscribe_<port>_<msg> registrations here.
}

{%- if n.config %}
// ---- config update — services/per casts ConfigUpdated when this statem
//      node's etcd-backed `config {{ n.config }}` changes. The GenServer base
//      (GenStateM derives from it) decoded the envelope + logged; apply the
//      typed config here (ParseFromString cfg.config into {{ n.config }}, honor
//      the changed mask; reach the FSM via h.data / post_event(*this, …)).
//      Empty default — a node that only reads config at boot leaves this as-is.
void {{ n.name }}::on_config_update(
        const platform_runtime_ConfigUpdated& /*cfg*/,
        ::theia::runtime::GenStateMHolder<{{ n.name }}State, {{ n.name }}Data>& /*h*/) {
}
{% endif %}

{# Server-port operations — deduplicated by (req_msg, rep_msg) so
   that multiple server ports sharing one interface don't produce
   duplicate handle_call signatures. #}
{%- for op in n.unique_handler_ops() %}
{{ op.rep_msg or "void" }} {{ n.name }}::handle_call(
        const {{ op.req_msg }}& /*req*/,
        ::theia::runtime::GenStateMHolder<{{ n.name }}State, {{ n.name }}Data>& /*h*/) {
    // TODO: map {{ op.name }} ({{ op.req_msg }} →
    // {{ op.rep_msg or "void" }}) onto an FSM event (e.g.
    // ::theia::runtime::post_event(*this, SomeEvent{})) or onto
    // daemon-side persistent state (via h.data).
    std::fprintf(stderr, "[%s] {{ op.name }} called\n",
                 kNodeName);
    {%- if op.rep_msg %}
    return {{ op.rep_msg }}{};
    {%- endif %}
}
{% endfor %}

}  // namespace {{ model.cxx_namespace }}
